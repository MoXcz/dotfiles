# Vim-like keybindings for Sioyek

# --- Basic movements ---
move_left           h
move_down           j
move_up             k
move_right          l

# --- Screen / page movement ---
screen_down         <C-d>
screen_up           <C-u>
screen_down         <space>
screen_up           <S-space>
screen_down         <pagedown>
screen_up           <pageup>

# --- History navigation ---
prev_state          <C-o>
next_state          <C-i>

# --- Go to start / end / specific page (gg / G style) ---
goto_begining       gg
goto_end            G
goto_page_with_page_number  <home>

# --- Searching and navigation within results ---
search              /
next_item           n
previous_item       <S-n>

# --- Table of contents, bookmarks, marks ---
goto_toc            t
add_bookmark        b
goto_bookmark       gb

# --- Zoom ---
zoom_in             +
zoom_out            -
zoom_out            =

# --- Highlighting controls ---
add_highlight                   v
delete_highlight                V
toggle_highlight_visibility     <C-h>

# --- Other helpful bindings ---
open_document       O            # recently opened
open_prev_doc       o            # open file dialog
command             :            # command palette (searchable list of commands)
toggle_statusbar       <C-w>

fit_to_page_width   zw
fit_to_page_height  zh

reload_config r

# vim-like view
center_view     zz
align_top       zt
align_bottom    zb

toggle_dark_mode w
toggle_custom_color c
